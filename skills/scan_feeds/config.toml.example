# scan_feeds configuration
#
# [settings] controls delegation and reading limits.
# [[category]] entries define feed sources.
#
# Settings:
#   max_age_hours         — skip items older than this (default: 48)
#   max_total_reads       — max articles to read via delegate (default: 6)
#   max_articles_per_feed — max articles to pick per feed (default: 2)
#   fetch_multiplier      — overfetch ratio for dedup headroom (default: 4)
#
# Feed fields:
#   name      — unique identifier (used in logs and feed filter)
#   type      — "rss" | "reddit" | "twitter" | "rsshub"
#   count     — max items to fetch from this source
#
# Type-specific fields:
#   rss:      url       — direct RSS/Atom feed URL
#   reddit:   subreddit — subreddit name (without r/)
#             sort      — "hot" | "new" | "top" | "rising"
#   twitter:  lists     — array of Twitter list IDs (fetched via RSSHub)
#             accounts  — array of Twitter handles (fetched via RSSHub)
#   rsshub:   route     — RSSHub route path (e.g. "/reuters/world")
#
# Twitter sources require SKILL_TWITTER_AUTH_TOKEN in .env.

[settings]
max_age_hours = 48
max_total_reads = 6
max_articles_per_feed = 2
fetch_multiplier = 4

# --- News ---

[[news]]
name = "reuters"
type = "rsshub"
route = "/reuters/world"
count = 5

[[news]]
name = "bbc-news"
type = "rss"
url = "http://feeds.bbci.co.uk/news/world/rss.xml"
count = 5

[[news]]
name = "ap-news"
type = "rss"
url = "https://apnews.com/feed"
count = 5

# --- Tech ---

[[tech]]
name = "ars-technica"
type = "rss"
url = "https://feeds.arstechnica.com/arstechnica/index"
count = 5

[[tech]]
name = "hackernews"
type = "rsshub"
route = "/hackernews/best"
count = 5

# --- Social / Reddit ---

[[social]]
name = "reddit-technology"
type = "reddit"
subreddit = "technology"
sort = "hot"
count = 5


# Single-action routine with interval trigger.
[check-calendar]
interval = "6 hours"
action = "search_calendar"
goal = "Alert about any events today or tomorrow."
silent_if_empty = true

# Action arguments with template expansion.
# Base templates: {{today}}, {{tomorrow}}, {{yesterday}}, {{now}}
# Relative offsets: {{now-2h}}, {{today+3d}}, {{yesterday-1w}}, {{now+30m}}
# Offset units: m (minutes), h (hours), d (days), w (weeks).
# All times expanded at execution time in local timezone.
[check-calendar-today]
interval = "4 hours"
action = "search_calendar"
goal = "Summarize today's remaining events."
silent_if_empty = true
action_args.search_calendar = { time_min = "{{today}}", time_max = "{{tomorrow}}" }

# Passing arbitrary (non-template) arguments to a skill.
# Any key/value pairs are passed as JSON args to the action.
# Non-string values (numbers, booleans) pass through as-is.
[feed-check]
interval = "4 hours"
action = "scan_feeds"
goal = "Send a digest of the top articles."
silent_if_empty = true
action_args.scan_feeds = { count = 5, feed = "ars-technica" }

# Multi-action routine with schedule trigger and action_args.
# Actions are called in order; results are concatenated and passed to the orchestrator.
# Skills (like scan_feeds) work alongside built-in tools in the same actions list.
[morning-briefing]
schedule = "06:00"
actions = ["search_email", "get_weather", "search_calendar", "scan_feeds"]
goal = "Synthesize the action results into a concise daily orientation (under 20 lines)."
action_args.search_calendar = { time_min = "{{today}}", time_max = "{{tomorrow}}" }
action_args.scan_feeds = { count = 5 }

# Multi-time schedule: fires at each listed time independently.
[standup-reminder]
schedule = ["09:00", "14:00"]
instruction = "Check calendar for meetings in the next hour and remind the user."

# Combined interval + schedule: fires on whichever trigger comes first.
# The schedule fires at 06:00 daily; the interval fires every 8 hours after that.
[feed-digest]
interval = "8 hours"
schedule = "06:00"
action = "scan_feeds"
goal = "Select 3-5 most interesting items. Send a digest with title, summary, and link."
silent_if_empty = true

# Evening recap: multi-action routine pulling tomorrow's schedule, any
# unresolved emails, and top stories into a relaxed end-of-day summary.
[evening-recap]
schedule = "20:00"
actions = ["search_calendar", "search_email", "scan_feeds"]
goal = "Generate an evening recap: tomorrow's schedule, emails needing attention, 2-3 top stories. Keep it under 15 lines."
action_args.search_calendar = { time_min = "{{tomorrow}}", time_max = "{{tomorrow+1d}}" }
action_args.scan_feeds = { count = 3 }
